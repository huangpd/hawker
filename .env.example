# HawkerAgent 环境变量配置模版

# --- 核心配置 (必需) ---
# LLM API 密钥 (支持 OpenAI / DeepSeek / 智谱等兼容接口)
OPENAI_API_KEY=sk-xxxx

# 模型名称 (示例: gpt-4o, deepseek-chat, o3-mini)
# 如果是自建 API 或特定 Provider，可能需要前缀: openai/gpt-4o
MODEL_NAME=gpt-4o

# --- LLM 高级配置 (可选) ---
# 自定义 API 地址 (示例: https://api.deepseek.com/v1)
# OPENAI_BASE_URL=

# 推理努力程度 (仅部分模型如 o1/o3-mini 支持: low, medium, high)
# REASONING_EFFORT=medium

# --- 运行预算与控制 (可选) ---
# 本次运行的最大 Token 总量限制 (防止过度消耗)
MAX_TOTAL_TOKENS=120000

# 连续无进展的最大步数 (超过此限制将自动终止任务并返回结果)
MAX_NO_PROGRESS_STEPS=10

# 消息压缩阈值 (超过此 Token 数时将自动压缩中间历史记录)
MESSAGE_COMPRESSION_TOKENS=12000

# --- 系统与浏览器 (可选) ---
# 结果产物保存目录
SCRAPE_DIR=crawler_agent

# 是否以无头模式运行浏览器 (true/false)
HEADLESS=false

# 系统日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
