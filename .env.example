# HawkerAgent 环境变量配置模版

# =========================
# 核心 LLM 配置（必填）
# =========================

# OpenAI 兼容接口的 API Key
OPENAI_API_KEY=sk-xxxx

# 主模型名称
# 示例:
# MODEL_NAME=openai/gpt-5.4
# MODEL_NAME=us.anthropic.claude-opus-4-6-v1
MODEL_NAME=openai/gpt-5.4

# 自定义 OpenAI 兼容接口地址（可选）
# OPENAI_BASE_URL=https://api.example.com/v1

# 主模型推理强度（仅部分模型支持）
# 可选: low / medium / high
REASONING_EFFORT=

# 小模型名称：Healing 与 Final Evaluator 共用
# 示例:
# SMALL_MODEL_NAME=gpt-4o-mini
# SMALL_MODEL_NAME=gpt-5.4-nano
SMALL_MODEL_NAME=gpt-5.4-nano

# =========================
# 运行控制
# =========================

# 最大迭代步数
MAX_STEPS=25

# 最大 Token 预算
MAX_TOTAL_TOKENS=200000

# 连续无进展最大步数
MAX_NO_PROGRESS_STEPS=10

# 历史消息压缩阈值
MESSAGE_COMPRESSION_TOKENS=12000

# =========================
# Healing / Final Evaluator
# =========================

# 是否启用局部代码修复
HEALER_ENABLED=true

# Healing 推理强度（可留空）
HEALER_REASONING_EFFORT=

# Healing 最大修复尝试次数
HEALER_MAX_ATTEMPTS=3

# 是否启用最终交付评估
FINAL_EVALUATOR_ENABLED=true

# 最终交付评估推理强度（可留空）
FINAL_EVALUATOR_REASONING_EFFORT=

# =========================
# Langfuse（可选）
# =========================

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=
LANGFUSE_ENVIRONMENT=development
LANGFUSE_RELEASE=

# =========================
# 文件系统 / 浏览器 / 日志
# =========================

# 运行产物目录
SCRAPE_DIR=hawker_file

# 是否无头浏览器
HEADLESS=false

# 日志级别
LOG_LEVEL=INFO
